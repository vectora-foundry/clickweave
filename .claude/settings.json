{
  "permissions": {
    "allow": [
      "Bash(git add*)",
      "Bash(git commit*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "cargo fmt --quiet 2>/dev/null || true && cargo clippy --quiet 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
