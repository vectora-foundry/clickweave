[llm]
endpoint = "http://localhost:8000/v1/chat/completions"
model = "Qwen3.5-27B-Q6_K"
# api_key = ""
# temperature = 0.7

# Multiple weighted endpoints:
# [[llm.endpoints]]
# url = "http://server-a:8000/v1/chat/completions"
# weight = 3
#
# [[llm.endpoints]]
# url = "http://server-b:8000/v1/chat/completions"
# weight = 1

[prompts]
planner = "prompts/planner.md"

[run]
cases_dir = "eval/cases"
tools_file = "eval/tools.json"
runs_per_case = 3
